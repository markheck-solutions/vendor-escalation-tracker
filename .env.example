# Public demo flags (safe to expose to the browser)
NEXT_PUBLIC_DEMO_MODE=true

# Server-only settings
AI_PROVIDER=mock

# Database (server-only). Leave blank in the repo.
DATABASE_URL=

# Supabase (public anon values are OK to expose, but do not commit real values here)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional private local OpenAI-compatible provider (server-only)
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
